{
  "$defs": {
    "BrandInfo": {
      "additionalProperties": false,
      "description": "Metadados essenciais da marca compilada.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "BrandInfo",
      "type": "object"
    },
    "ColorToken": {
      "additionalProperties": false,
      "description": "Cor semântica normalizada com sua cadeia de evidências.",
      "properties": {
        "value": {
          "title": "Value",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "required": [
        "value",
        "evidence"
      ],
      "title": "ColorToken",
      "type": "object"
    },
    "Diagnostic": {
      "additionalProperties": false,
      "description": "Lacuna ou decisão pendente comunicada em linguagem orientada à ação.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "resolution": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolution"
        }
      },
      "required": [
        "code",
        "target",
        "message"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "Evidence": {
      "additionalProperties": false,
      "description": "Rastro de origem de um valor da marca, com confiança e autoridade.",
      "properties": {
        "sourceType": {
          "enum": [
            "pdf-guideline",
            "svg-asset",
            "raster-asset",
            "font-file",
            "font-catalog",
            "dtcg-tokens",
            "wizard-confirmation",
            "manual-entry"
          ],
          "title": "Sourcetype",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "authoritative": {
          "default": false,
          "title": "Authoritative",
          "type": "boolean"
        },
        "confirmedAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confirmedat"
        }
      },
      "required": [
        "sourceType",
        "confidence"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "FontAxis": {
      "additionalProperties": false,
      "description": "Intervalo de um eixo OpenType variável, preservado para reprodução.",
      "properties": {
        "tag": {
          "maxLength": 4,
          "minLength": 4,
          "pattern": "^[A-Za-z0-9]{4}$",
          "title": "Tag",
          "type": "string"
        },
        "minimum": {
          "title": "Minimum",
          "type": "number"
        },
        "default": {
          "type": "number",
          "title": "Default"
        },
        "maximum": {
          "title": "Maximum",
          "type": "number"
        }
      },
      "required": [
        "tag",
        "minimum",
        "default",
        "maximum"
      ],
      "title": "FontAxis",
      "type": "object"
    },
    "FontResource": {
      "additionalProperties": false,
      "description": "Binário de fonte resolvido com origem, licença e cobertura verificáveis.",
      "properties": {
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "format": {
          "enum": [
            "ttf",
            "otf",
            "woff2"
          ],
          "title": "Format",
          "type": "string"
        },
        "upstreamRef": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upstreamref"
        },
        "licenseId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Licenseid"
        },
        "licenseSha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Licensesha256"
        },
        "usagePolicy": {
          "default": "unknown",
          "enum": [
            "redistributable",
            "embeddable",
            "restricted",
            "unknown"
          ],
          "title": "Usagepolicy",
          "type": "string"
        },
        "coverageProfile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Coverageprofile"
        },
        "missingCodepoints": {
          "items": {
            "type": "integer"
          },
          "title": "Missingcodepoints",
          "type": "array"
        },
        "axes": {
          "items": {
            "$ref": "#/$defs/FontAxis"
          },
          "title": "Axes",
          "type": "array"
        }
      },
      "required": [
        "provider",
        "format"
      ],
      "title": "FontResource",
      "type": "object"
    },
    "FontToken": {
      "additionalProperties": false,
      "description": "Fonte semântica confirmada, ligada ou não a um arquivo local.",
      "properties": {
        "family": {
          "title": "Family",
          "type": "string"
        },
        "weight": {
          "default": 400,
          "maximum": 900,
          "minimum": 100,
          "title": "Weight",
          "type": "integer"
        },
        "style": {
          "default": "normal",
          "enum": [
            "normal",
            "italic"
          ],
          "title": "Style",
          "type": "string"
        },
        "source": {
          "enum": [
            "file",
            "referenced-only",
            "fallback"
          ],
          "title": "Source",
          "type": "string"
        },
        "fileSha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filesha256"
        },
        "resource": {
          "anyOf": [
            {
              "$ref": "#/$defs/FontResource"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "required": [
        "family",
        "source",
        "evidence"
      ],
      "title": "FontToken",
      "type": "object"
    },
    "LogoAsset": {
      "additionalProperties": false,
      "description": "Asset de logo publicado com integridade e proveniência confirmada.",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "format": {
          "enum": [
            "svg",
            "png"
          ],
          "title": "Format",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "title": "Evidence",
          "type": "array"
        },
        "minWidthPx": {
          "default": 96,
          "title": "Minwidthpx",
          "type": "integer"
        },
        "clearSpaceRatio": {
          "default": 0.25,
          "title": "Clearspaceratio",
          "type": "number"
        }
      },
      "required": [
        "path",
        "sha256",
        "format",
        "evidence"
      ],
      "title": "LogoAsset",
      "type": "object"
    },
    "RevisionInfo": {
      "additionalProperties": false,
      "description": "Identidade determinística e instante de auditoria de uma revisão.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "createdAt": {
          "format": "date-time",
          "title": "Createdat",
          "type": "string"
        }
      },
      "required": [
        "id",
        "createdAt"
      ],
      "title": "RevisionInfo",
      "type": "object"
    },
    "SemanticRole": {
      "additionalProperties": false,
      "description": "Papel tipográfico que referencia tokens de fonte e cor do Brand IR.",
      "properties": {
        "font": {
          "title": "Font",
          "type": "string"
        },
        "color": {
          "title": "Color",
          "type": "string"
        },
        "minSizePx": {
          "title": "Minsizepx",
          "type": "integer"
        },
        "maxSizePx": {
          "title": "Maxsizepx",
          "type": "integer"
        },
        "lineHeight": {
          "title": "Lineheight",
          "type": "number"
        }
      },
      "required": [
        "font",
        "color",
        "minSizePx",
        "maxSizePx",
        "lineHeight"
      ],
      "title": "SemanticRole",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Contrato imutável da marca consumido pelo kit, guard e renderer.",
  "properties": {
    "schemaVersion": {
      "default": "0.2.0",
      "enum": [
        "0.1.0",
        "0.2.0"
      ],
      "title": "Schemaversion",
      "type": "string"
    },
    "brand": {
      "$ref": "#/$defs/BrandInfo"
    },
    "revision": {
      "$ref": "#/$defs/RevisionInfo"
    },
    "colors": {
      "additionalProperties": {
        "$ref": "#/$defs/ColorToken"
      },
      "title": "Colors",
      "type": "object"
    },
    "fonts": {
      "additionalProperties": {
        "$ref": "#/$defs/FontToken"
      },
      "title": "Fonts",
      "type": "object"
    },
    "roles": {
      "additionalProperties": {
        "$ref": "#/$defs/SemanticRole"
      },
      "title": "Roles",
      "type": "object"
    },
    "assets": {
      "additionalProperties": {
        "$ref": "#/$defs/LogoAsset"
      },
      "title": "Assets",
      "type": "object"
    },
    "formatProfiles": {
      "default": [
        "post-1x1",
        "post-4x5",
        "story-9x16",
        "doc-a4"
      ],
      "items": {
        "type": "string"
      },
      "title": "Formatprofiles",
      "type": "array"
    },
    "diagnostics": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Diagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    }
  },
  "required": [
    "brand",
    "revision",
    "colors",
    "fonts",
    "roles",
    "assets"
  ],
  "title": "BrandIR",
  "type": "object"
}
