{
  "$defs": {
    "ImageValue": {
      "additionalProperties": false,
      "description": "Imagem fornecida para um slot, opcionalmente acompanhada de seu hash.",
      "properties": {
        "kind": {
          "const": "image",
          "default": "image",
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        }
      },
      "required": [
        "path"
      ],
      "title": "ImageValue",
      "type": "object"
    },
    "LayerOverride": {
      "additionalProperties": false,
      "description": "Ajustes autorais de uma instância sem alterar o layout publicado.",
      "properties": {
        "area": {
          "anyOf": [
            {
              "maxItems": 4,
              "minItems": 4,
              "prefixItems": [
                {
                  "maximum": 32768,
                  "minimum": -32768,
                  "type": "integer"
                },
                {
                  "maximum": 32768,
                  "minimum": -32768,
                  "type": "integer"
                },
                {
                  "exclusiveMinimum": 0,
                  "maximum": 32768,
                  "type": "integer"
                },
                {
                  "exclusiveMinimum": 0,
                  "maximum": 32768,
                  "type": "integer"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Area"
        },
        "opacity": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Opacity"
        },
        "hidden": {
          "default": false,
          "title": "Hidden",
          "type": "boolean"
        },
        "zIndex": {
          "anyOf": [
            {
              "maximum": 20,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Zindex"
        },
        "colorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Colortoken"
        },
        "fontToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fonttoken"
        },
        "fontSizePx": {
          "anyOf": [
            {
              "maximum": 1024.0,
              "minimum": 6.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontsizepx"
        },
        "fontWeight": {
          "anyOf": [
            {
              "maximum": 900,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontweight"
        },
        "fontStyle": {
          "anyOf": [
            {
              "enum": [
                "normal",
                "italic"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fontstyle"
        },
        "lineHeight": {
          "anyOf": [
            {
              "maximum": 3.0,
              "minimum": 0.5,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lineheight"
        },
        "letterSpacingEm": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": -0.25,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Letterspacingem"
        },
        "textAlign": {
          "anyOf": [
            {
              "enum": [
                "left",
                "center",
                "right"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Textalign"
        },
        "textTransform": {
          "anyOf": [
            {
              "enum": [
                "none",
                "uppercase"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Texttransform"
        },
        "fillMode": {
          "anyOf": [
            {
              "enum": [
                "fill",
                "stroke"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fillmode"
        },
        "strokeColorToken": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokecolortoken"
        },
        "strokeWidthPx": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 20.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strokewidthpx"
        },
        "fit": {
          "anyOf": [
            {
              "enum": [
                "contain",
                "cover"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fit"
        },
        "spacingPx": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 256.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spacingpx"
        }
      },
      "title": "LayerOverride",
      "type": "object"
    },
    "SurfaceStyle": {
      "additionalProperties": false,
      "description": "Textura procedural de uma peça, editável e recortada pelo canvas.",
      "properties": {
        "kind": {
          "enum": [
            "paper-grain",
            "linear-rhythm",
            "technical-grid",
            "point-field",
            "concentric-rings"
          ],
          "title": "Kind",
          "type": "string"
        },
        "colorToken": {
          "minLength": 1,
          "pattern": ".*\\S.*",
          "title": "Colortoken",
          "type": "string"
        },
        "opacity": {
          "default": 0.12,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Opacity",
          "type": "number"
        },
        "scalePx": {
          "default": 48.0,
          "maximum": 512.0,
          "minimum": 4.0,
          "title": "Scalepx",
          "type": "number"
        },
        "weightPx": {
          "default": 1.0,
          "exclusiveMinimum": 0.0,
          "maximum": 32.0,
          "title": "Weightpx",
          "type": "number"
        },
        "angleDeg": {
          "default": 0.0,
          "maximum": 180.0,
          "minimum": -180.0,
          "title": "Angledeg",
          "type": "number"
        }
      },
      "required": [
        "kind",
        "colorToken"
      ],
      "title": "SurfaceStyle",
      "type": "object"
    },
    "TextValue": {
      "additionalProperties": false,
      "description": "Conteúdo textual fornecido para um slot.",
      "properties": {
        "kind": {
          "const": "text",
          "default": "text",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "emphasis": {
          "anyOf": [
            {
              "minLength": 1,
              "pattern": ".*\\S.*",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Emphasis"
        }
      },
      "required": [
        "text"
      ],
      "title": "TextValue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Conteúdo de uma peça ligado a um layout e a uma revisão de marca.",
  "properties": {
    "layoutId": {
      "minLength": 1,
      "pattern": ".*\\S.*",
      "title": "Layoutid",
      "type": "string"
    },
    "brandRevisionId": {
      "minLength": 1,
      "pattern": ".*\\S.*",
      "title": "Brandrevisionid",
      "type": "string"
    },
    "values": {
      "additionalProperties": {
        "anyOf": [
          {
            "$ref": "#/$defs/TextValue"
          },
          {
            "$ref": "#/$defs/ImageValue"
          }
        ]
      },
      "title": "Values",
      "type": "object"
    },
    "overrides": {
      "additionalProperties": {
        "$ref": "#/$defs/LayerOverride"
      },
      "title": "Overrides",
      "type": "object"
    },
    "surface": {
      "anyOf": [
        {
          "$ref": "#/$defs/SurfaceStyle"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "layoutId",
    "brandRevisionId",
    "values"
  ],
  "title": "ContentSpec",
  "type": "object"
}
