[Unit]
Description=Brand Runtime test application
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target
ConditionPathExists=/opt/brand-runtime/current/docker-compose.yml

[Service]
Type=oneshot
WorkingDirectory=/opt/brand-runtime/current
ExecStart=/usr/bin/docker compose -f docker-compose.yml -f infra/hosting/compose.hosted-assets.yml up -d --wait --wait-timeout 900
ExecStop=/usr/bin/docker compose -f docker-compose.yml -f infra/hosting/compose.hosted-assets.yml stop
RemainAfterExit=yes
TimeoutStartSec=1200
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
